import operator
from typing import TypedDict, Annotated, List
from langgraph.graph import StateGraph, END
from langchain_openai import ChatOpenAI
from langchain_core.messages import HumanMessage

# --- 1. Define the State ---
# This mirrors the data flowing through the sequence diagram.
class AgentState(TypedDict):
    coaching_direction: str
    current_prompt: str
    new_prompt: str
    rationale: str
    status: str  # e.g., "Pending", "Flagged_Injection", "Pending_Approval", "Approved"
    audit_trail: Annotated[List[str], operator.add]
    attempts: int

# --- 2. Define the Tools/Agents (Mocking the Diagram Components) ---

# Mock Database (PostgreSQL)
class MockPostgreSQL:
    def get_approved_prompt(self, agent_id):
        return "You are a helpful assistant."
    
    def save_prompt(self, prompt, status, rationale):
        print(f"[DB] Saving prompt with status: {status}")
        print(f"[DB] Rationale: {rationale}")

# Mock LLMs for Agents
llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

def architect_agent(state: AgentState) -> dict:
    """
    Corresponds to 'Agent 5 Prompt Architect' in the diagram.
    Reads current prompt, performs pattern check, rewrites.
    """
    print("\n--- [Agent 5: Architect] Starting ---")
    
    # Step 5: Read current approved prompt
    current = MockPostgreSQL().get_approved_prompt("target_agent")
    
    # Step 6: Pattern check + semantic check (Simulated)
    direction = state['coaching_direction']
    is_injection = "hack" in direction.lower() or "ignore" in direction.lower()

    if is_injection:
        # [Injection flagged] path
        print("[Agent 5] ⚠️ Injection detected! Escalating.")
        return {
            "status": "Flagged_Injection",
            "audit_trail": ["Injection flagged by Architect"]
        }
    else:
        # Clean path: Rewrite prompt
        response = llm.invoke([HumanMessage(content=f"""
            Rewrite the following prompt based on this direction: {direction}.
            Original: {current}
            Provide the new prompt and a short rationale.
        """)])
        
        new_prompt = response.content
        rationale = "Generated by Architect based on coaching direction."
        
        print(f"[Agent 5] ✅ Rewrote prompt. Status: Pending_Approval")
        return {
            "current_prompt": current,
            "new_prompt": new_prompt,
            "rationale": rationale,
            "status": "Pending_Approval"
        }

def reviewer_agent(state: AgentState) -> dict:
    """
    Corresponds to 'Agent 4 Reviewer' in the diagram.
    Validates the candidate (faithfulness check).
    """
    print("\n--- [Agent 4: Reviewer] Validating ---")
    
    # Step 11: Validate candidate (faithfulness)
    # In a real scenario, this agent checks if the new prompt actually follows the direction
    # without breaking safety guidelines.
    
    print("[Agent 4] Validating faithfulness...")
    # Assuming it passes for this demo
    return {
        "audit_trail": ["Reviewer validated faithfulness"]
    }

def human_review_node(state: AgentState) -> dict:
    """
    Corresponds to the 'Coach' and 'UI' interaction.
    The UI shows the diff, the Coach clicks Accept.
    """
    print("\n--- [UI/Coach] Review Phase ---")
    print(f"Current Prompt: {state['current_prompt']}")
    print(f"New Prompt: {state['new_prompt']}")
    print(f"Rationale: {state['rationale']}")
    
    # Simulating the Coach's decision
    # In a real app, this would be an interrupt() waiting for API call
    decision = input("\nCoach, do you Accept? (yes/no): ").lower()
    
    if decision == 'yes':
        return {"status": "Approved"}
    else:
        return {"status": "Rejected"}

def finalize_node(state: AgentState) -> dict:
    """
    Corresponds to the final steps:
    - Previous Approved -> Superseded
    - New candidate -> Approved
    - Increment attempts counter
    """
    print("\n--- [Orchestrator] Finalizing ---")
    
    MockPostgreSQL().save_prompt(state['new_prompt'], "Approved", state['rationale'])
    
    # Step 19: Increment attempts counter
    attempts = state.get('attempts', 0) + 1
    
    return {
        "audit_trail": ["Previous Superseded", "New Approved", "Audit Trail Updated"],
        "attempts": attempts
    }

# --- 3. Define Routing Logic ---

def route_after_architect(state: AgentState):
    """
    Checks if the Architect flagged an injection.
    """
    if state['status'] == "Flagged_Injection":
        return "flagged_handler"
    else:
        return "reviewer"

def route_after_human(state: AgentState):
    """
    Checks if the Coach accepted.
    """
    if state['status'] == "Approved":
        return "finalize"
    else:
        return "end_rejected"

# --- 4. Build the Graph ---

workflow = StateGraph(AgentState)

# Add Nodes
# Step 1 & 2: Receive direction and set row (Pending)
workflow.add_node("receive_direction", lambda state: state) 

# Step 3 & 4: Rewrite prompt
workflow.add_node("architect", architect_agent)

# Step 11: Validate candidate
workflow.add_node("reviewer", reviewer_agent)

# Step 12, 13, 14: UI Display and Coach Decision
workflow.add_node("human_review", human_review_node)

# Step 17, 18, 19: Finalize
workflow.add_node("finalize", finalize_node)

# Handling the [Injection Flagged] path
workflow.add_node("flagged_handler", lambda state: print("[System] Stopping due to injection flag.") or state)
workflow.add_node("end_rejected", lambda state: print("[System] Coach rejected the prompt.") or state)

# Set Entry Point
workflow.set_entry_point("receive_direction")

# Add Edges
# 1. Start -> Architect
workflow.add_edge("receive_direction", "architect")

# 2. Architect -> Conditional (Injection vs Clean)
workflow.add_conditional_edges(
    "architect",
    route_after_architect,
    {
        "reviewer": "reviewer",
        "flagged_handler": "flagged_handler"
    }
)

# 3. If Flagged -> End
workflow.add_edge("flagged_handler", END)

# 4. Reviewer -> Human Review
workflow.add_edge("reviewer", "human_review")

# 5. Human Review -> Conditional (Accept vs Reject)
workflow.add_conditional_edges(
    "human_review",
    route_after_human,
    {
        "finalize": "finalize",
        "end_rejected": "end_rejected"
    }
)

# 6. Finalize -> End
workflow.add_edge("finalize", END)
workflow.add_edge("end_rejected", END)

# Compile the graph
app = workflow.compile()

# --- 5. Run the Graph ---

if __name__ == "__main__":
    # Initial State: Coach submits coaching direction (Step 1)
    initial_state = {
        "coaching_direction": "Make the assistant answer in pirate speak.",
        "status": "Pending",
        "attempts": 0,
        "audit_trail": []
    }

    print("Starting Workflow...")
    final_state = app.invoke(initial_state)
    
    print("\n--- Final State ---")
    print(final_state)
