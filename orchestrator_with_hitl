"""
Orchestrator agent (LangGraph) with:
  1. 3 agents (researcher, critic, creative) running IN PARALLEL
  2. Human-in-the-loop (HITL) approval inside EACH of those 3 agents
  3. A dedicated reviewer agent for each of the 3 outputs
  4. A final aggregator that combines everything

Graph shape
-----------
                    START
                /      |      \\
         researcher  critic  creative      <- run concurrently
          (HITL)     (HITL)   (HITL)       <- each pauses for human approval
              |         |         |
     researcher_   critic_   creative_
      reviewer     reviewer   reviewer     <- reviews that agent's approved output
              \\        |         /
                    aggregator
                        |
                       END

How HITL works here
--------------------
Each agent node calls LangGraph's `interrupt(...)` after producing a draft.
`interrupt()` pauses ONLY that branch and surfaces a payload to the caller.
The graph run returns with an `__interrupt__` key listing every pending
interrupt (one per parallel branch, each with its own `.id`). The driver
loop below collects a human decision for each pending interrupt and resumes
the whole graph with `Command(resume={interrupt_id: value, ...})`.

This requires a checkpointer (here: MemorySaver) because the graph's
state must be persisted across the pause/resume cycle.

Install:
    pip install -U langgraph langchain-core langchain-anthropic

Run:
    export ANTHROPIC_API_KEY=sk-ant-...     # optional, see MOCK_MODE below
    python orchestrator_agent.py "What should our Q3 marketing focus be?"
"""

import os
import time
import operator
from typing import TypedDict, Annotated

from langgraph.graph import StateGraph, START, END
from langgraph.types import interrupt, Command
from langgraph.checkpoint.memory import MemorySaver

# ---------------------------------------------------------------------------
# 1. Try to use real Claude-backed agents; fall back to mock agents if no key
# ---------------------------------------------------------------------------
MOCK_MODE = "ANTHROPIC_API_KEY" not in os.environ

if not MOCK_MODE:
    from langchain_anthropic import ChatAnthropic

    llm = ChatAnthropic(model="claude-sonnet-4-6", max_tokens=500)

    def call_llm(system_prompt: str, user_prompt: str) -> str:
        resp = llm.invoke(
            [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt},
            ]
        )
        return resp.content
else:
    def call_llm(system_prompt: str, user_prompt: str) -> str:
        time.sleep(0.3)  # simulate latency
        return f"[MOCK | persona: {system_prompt[:30]}...] -> {user_prompt[:80]}"


# ---------------------------------------------------------------------------
# 2. Shared graph state
#    `agent_responses` and `reviews` use operator.add reducers so parallel
#    branches can each append without clobbering the others.
# ---------------------------------------------------------------------------
class OrchestratorState(TypedDict):
    query: str
    agent_responses: Annotated[list, operator.add]
    reviews: Annotated[list, operator.add]
    final_response: str


# ---------------------------------------------------------------------------
# 3. Agent node factory — draft response, then HITL approval via interrupt()
# ---------------------------------------------------------------------------
def make_agent_node(agent_name: str, persona: str):
    def node(state: OrchestratorState) -> dict:
        draft = call_llm(persona, state["query"])

        # Pause this branch and hand control back to the human.
        # `interrupt()` returns whatever value the human supplies on resume.
        human_decision = interrupt(
            {
                "agent": agent_name,
                "draft_response": draft,
                "action_needed": "approve | edit | reject",
                "instructions": (
                    f"Review the {agent_name} agent's draft. Resume with either "
                    f"the string 'approve' to keep it as-is, or a replacement "
                    f"string to use as the edited final response."
                ),
            }
        )

        if isinstance(human_decision, str) and human_decision.strip().lower() == "approve":
            final_text = draft
        elif isinstance(human_decision, str) and human_decision.strip():
            final_text = human_decision  # human-edited text
        else:
            final_text = draft  # default: no usable input, keep draft

        return {"agent_responses": [{"agent": agent_name, "response": final_text}]}

    return node


researcher_agent = make_agent_node(
    "researcher", "You are a meticulous researcher. Provide facts and data."
)
critic_agent = make_agent_node(
    "critic", "You are a sharp critic. Point out risks and weaknesses."
)
creative_agent = make_agent_node(
    "creative", "You are a creative strategist. Propose bold, novel ideas."
)


# ---------------------------------------------------------------------------
# 4. Reviewer node factory — one reviewer per agent output, no HITL needed
# ---------------------------------------------------------------------------
def make_reviewer_node(agent_name: str):
    def node(state: OrchestratorState) -> dict:
        entry = next(r for r in state["agent_responses"] if r["agent"] == agent_name)
        review_prompt = (
            f"Review the following {agent_name} response for accuracy, clarity, "
            f"and usefulness. Give a short critique and a 1-10 score.\n\n"
            f"Response:\n{entry['response']}"
        )
        review = call_llm(
            f"You are a meticulous quality reviewer for {agent_name}-style outputs.",
            review_prompt,
        )
        return {"reviews": [{"agent": agent_name, "review": review}]}

    return node


researcher_reviewer = make_reviewer_node("researcher")
critic_reviewer = make_reviewer_node("critic")
creative_reviewer = make_reviewer_node("creative")


# ---------------------------------------------------------------------------
# 5. Aggregator — runs once all 3 reviewer branches complete
# ---------------------------------------------------------------------------
def aggregator(state: OrchestratorState) -> dict:
    blocks = []
    for r in state["agent_responses"]:
        review = next((rv["review"] for rv in state["reviews"] if rv["agent"] == r["agent"]), "N/A")
        blocks.append(
            f"### {r['agent'].title()}\n"
            f"**Response:** {r['response']}\n\n"
            f"**Review:** {review}"
        )
    combined = "\n\n".join(blocks)
    final = (
        f"# Orchestrated Answer for: {state['query']}\n\n"
        f"{combined}\n\n"
        f"---\n"
        f"**Synthesis:** {len(state['agent_responses'])} human-approved agent outputs, "
        f"each independently reviewed."
    )
    return {"final_response": final}


# ---------------------------------------------------------------------------
# 6. Build the graph
# ---------------------------------------------------------------------------
def build_graph():
    graph = StateGraph(OrchestratorState)

    graph.add_node("researcher", researcher_agent)
    graph.add_node("critic", critic_agent)
    graph.add_node("creative", creative_agent)

    graph.add_node("researcher_review", researcher_reviewer)
    graph.add_node("critic_review", critic_reviewer)
    graph.add_node("creative_review", creative_reviewer)

    graph.add_node("aggregator", aggregator)

    # Fan-out: all three agents run concurrently in the same super-step
    graph.add_edge(START, "researcher")
    graph.add_edge(START, "critic")
    graph.add_edge(START, "creative")

    # Each agent's (HITL-approved) output goes to its own reviewer
    graph.add_edge("researcher", "researcher_review")
    graph.add_edge("critic", "critic_review")
    graph.add_edge("creative", "creative_review")

    # Fan-in: aggregator waits for all three reviewers to finish
    graph.add_edge("researcher_review", "aggregator")
    graph.add_edge("critic_review", "aggregator")
    graph.add_edge("creative_review", "aggregator")

    graph.add_edge("aggregator", END)

    # Checkpointer is REQUIRED for interrupt()/Command(resume=...) to work
    checkpointer = MemorySaver()
    return graph.compile(checkpointer=checkpointer)


# ---------------------------------------------------------------------------
# 7. Driver loop: runs the graph, handles every pending interrupt, resumes,
#    and repeats until the graph completes.
# ---------------------------------------------------------------------------
def run_with_hitl(app, query: str, thread_id: str = "1"):
    config = {"configurable": {"thread_id": thread_id}}
    result = app.invoke(
        {"query": query, "agent_responses": [], "reviews": [], "final_response": ""},
        config=config,
    )

    # Keep resuming until there are no more pending interrupts
    while "__interrupt__" in result:
        pending = result["__interrupt__"]
        resume_map = {}

        print(f"\n--- {len(pending)} agent(s) waiting for human review ---")
        for intr in pending:
            payload = intr.value
            print(f"\n[{payload['agent'].upper()}] draft:\n{payload['draft_response']}")
            human_input = input(
                f"Type 'approve' to accept, or type replacement text for '{payload['agent']}': "
            ).strip()
            resume_map[intr.id] = human_input if human_input else "approve"

        result = app.invoke(Command(resume=resume_map), config=config)

    return result


# ---------------------------------------------------------------------------
# 8. Entry point
# ---------------------------------------------------------------------------
if __name__ == "__main__":
    import sys

    query = sys.argv[1] if len(sys.argv) > 1 else "How should we launch our new product?"

    if MOCK_MODE:
        print("(No ANTHROPIC_API_KEY found — running in MOCK MODE with fake LLM agents)")

    app = build_graph()
    final_state = run_with_hitl(app, query)

    print("\n" + "=" * 80)
    print(final_state["final_response"])
