"""
Combined LangGraph workflow.

This merges two previously separate graphs into a single pipeline:

  PART A — Prompt Coaching / Approval  (from type1.py)
      Coach -> UI -> Orchestrator -> Agent 5 (Prompt Architect) -> Agent 4
      (Reviewer) -> Postgres -> Architect Escalation Inbox, ending when the
      Coach Accepts a candidate prompt (or the circuit breaker trips / an
      injection is confirmed, which halt the run instead).

  PART B — Agentic Research/Reconciliation/Synthesis workflow
           (from agentic_workflow.py)
      UI Layer -> Orchestrator -> Agent 1 (Research) -> Agent 2A (Modeler)
      -> Agent 2B (Analyst) -> Agent 2C (Reconciliation) -> Agent 3 (Rec SME)
      -> Agent 4 (Reviewer) -> PostgreSQL (audit) -> HITL approval -> roadmap.

Join point
----------
Part A's `retrigger_and_validate_output` node (reached only once the Coach
has clicked **Accept** on the Prompt Diff Viewer, i.e. the prompt candidate
is Approved) no longer terminates the graph. Instead, once the newly
approved prompt's output has been validated, execution flows straight into
Part B's `configure_project` node, so the whole research -> reconciliation
-> synthesis -> roadmap pipeline runs using the freshly approved prompt.

The circuit-breaker-tripped and confirmed-injection paths still end the run
early (there is no approved prompt to hand off in those cases).

Both halves keep their own audit mechanisms:
  - Part A appends human-readable strings to `audit_log` (Postgres-style).
  - Part B appends structured dict rows to `audit_trail` (also written to
    Postgres via `write_audit_row`).
Both lists coexist on the combined state so nothing from either original
graph is lost.
"""

from __future__ import annotations

import operator
import uuid
from datetime import datetime, timezone
from typing import Annotated, Any, Literal, Optional, TypedDict

from langgraph.checkpoint.memory import MemorySaver
from langgraph.graph import StateGraph, START, END
from langgraph.types import interrupt, Command

# ---------------------------------------------------------------------------
# Optional: real Postgres audit sink for Part B. Falls back to an in-memory
# print if no DSN / driver is available, so the graph is runnable standalone.
# ---------------------------------------------------------------------------
try:
    import psycopg2

    HAS_PSYCOPG2 = True
except ImportError:
    HAS_PSYCOPG2 = False

POSTGRES_DSN = None  # e.g. "postgresql://user:pass@localhost:5432/orchestrator"

MAX_ATTEMPTS_PER_AGENT_PER_PROJECT = 10


# ---------------------------------------------------------------------------
# Combined state — union of both original WorkflowState schemas
# ---------------------------------------------------------------------------
class PromptCandidate(TypedDict):
    id: str
    proposed_prompt_text: str
    rationale: str
    status: str  # Flagged_Injection | Pending_Approval | Approved | Rejected | Superseded


class CombinedState(TypedDict, total=False):
    # --- Part A: Prompt coaching / approval -------------------------------
    project_id: str
    target_agent: str

    coaching_feedback_id: Optional[str]
    coaching_direction: Optional[str]

    base_prompt_version: Optional[str]
    current_prompt_text: str  # the currently approved / "old" prompt

    injection_flagged: Optional[bool]
    candidate: Optional[PromptCandidate]
    escalation_decision: Optional[Literal["dismiss", "confirm"]]
    coach_visible_status: Optional[str]  # e.g. "Under review"

    faithfulness_ok: Optional[bool]
    coach_decision: Optional[Literal["accept", "reject"]]
    coach_rationale: Optional[str]
    fresh_direction: Optional[str]

    attempts: int  # approved + rejected count, per agent/project
    circuit_breaker_tripped: bool
    output_validated: Optional[bool]

    audit_log: Annotated[list[str], operator.add]  # Part A audit trail

    # --- Part B: Agentic research / reconciliation / synthesis ------------
    run_id: str
    project_config: dict[str, Any]
    orchestration_state: dict[str, Any]

    market_intelligence: dict[str, Any]           # Agent 1 output
    documented_process_model: dict[str, Any]      # Agent 2A output
    observed_process_model: dict[str, Any]        # Agent 2B output
    draft_status_flags: dict[str, str]

    coaching_feedback: Optional[str]
    iteration_count: int
    max_iterations: int

    reconciliation_ready: bool
    reconciled_process_item: dict[str, Any]
    reconciliation_confirmed: bool

    proposed_interventions: dict[str, Any]
    interventions_verified: bool

    approval_decision: Optional[Literal["approve", "reject", "rework"]]

    status: str
    roadmap: dict[str, Any]

    audit_trail: Annotated[list[dict[str, Any]], operator.add]  # Part B audit trail


# ---------------------------------------------------------------------------
# Part A helpers (simulated external systems — swap for real DB / model calls)
# ---------------------------------------------------------------------------
def _postgres_write(event: str) -> str:
    return f"[postgres] {event}"


def _read_base_prompt_version(target_agent: str) -> str:
    """Agent 5 -> Postgres: read current approved prompt for target_agent."""
    return f"<current approved prompt for {target_agent}>"


def _agent5_pattern_and_semantic_check(direction: str) -> bool:
    """Agent 5's self-check on the coaching direction. Returns True if a
    prompt-injection attempt is flagged."""
    suspicious_markers = ("ignore previous", "disregard system", "reveal system prompt")
    return any(marker in direction.lower() for marker in suspicious_markers)


def _agent5_generate_candidate(target_agent: str, base_prompt: str, direction: str) -> PromptCandidate:
    """Agent 5 (Prompt Architect) drafts a revised prompt from the direction."""
    return {
        "id": str(uuid.uuid4()),
        "proposed_prompt_text": f"<revision of '{base_prompt}' for {target_agent} per: {direction}>",
        "rationale": "Incorporates coaching direction while preserving original intent.",
        "status": "Pending_Approval",
    }


def _agent4_validate_faithfulness(candidate: PromptCandidate) -> bool:
    return True


def _agent4_validate_output(new_prompt_text: str) -> bool:
    return True


# ---------------------------------------------------------------------------
# Part B helpers
# ---------------------------------------------------------------------------
def write_audit_row(record: dict[str, Any]) -> None:
    """Persist one audit_trail row (+ status flag) to PostgreSQL. Falls back
    to a no-op print if psycopg2/DSN aren't configured."""
    if HAS_PSYCOPG2 and POSTGRES_DSN:
        conn = psycopg2.connect(POSTGRES_DSN)
        try:
            with conn.cursor() as cur:
                cur.execute(
                    """
                    INSERT INTO audit_trail
                        (id, run_id, stage, status, payload, created_at)
                    VALUES (%s, %s, %s, %s, %s, %s)
                    """,
                    (
                        str(uuid.uuid4()),
                        record["run_id"],
                        record["stage"],
                        record["status"],
                        str(record.get("payload", {})),
                        datetime.now(timezone.utc),
                    ),
                )
            conn.commit()
        finally:
            conn.close()
    else:
        print(f"[audit_trail] {record['stage']:<28} status={record['status']}")


def _audit(state: CombinedState, stage: str, status: str, payload: Any = None) -> dict:
    """Build one audit record, write it to Postgres, and return the delta
    to merge into state['audit_trail']."""
    record = {
        "run_id": state.get("run_id"),
        "stage": stage,
        "status": status,
        "payload": payload or {},
        "ts": datetime.now(timezone.utc).isoformat(),
    }
    write_audit_row(record)
    return {"audit_trail": [record]}


# ===========================================================================
# PART A NODES — Prompt Coaching / Approval
# ===========================================================================
def receive_coaching_direction(state: CombinedState) -> dict:
    """Steps 1-2: Coach submits a direction; Orchestrator opens a Pending row."""
    if state.get("coaching_direction"):
        direction = state["coaching_direction"]
    else:
        response = interrupt({
            "ui": "Submit coaching direction",
            "target_agent": state["target_agent"],
        })
        direction = response["coaching_direction"]

    return {
        "coaching_direction": direction,
        "coaching_feedback_id": str(uuid.uuid4()),
        "coach_visible_status": "Pending",
        "audit_log": [_postgres_write(
            f"coaching_feedback row created (Pending) for {state['target_agent']}"
        )],
    }


def write_coaching_feedback(state: CombinedState) -> dict:
    """Step 3: Orchestrator -> Postgres: Write coaching_feedback."""
    return {
        "audit_log": [_postgres_write(
            f"coaching_feedback {state['coaching_feedback_id']} written: "
            f"{state['coaching_direction']!r}"
        )]
    }


def agent5_read_base_prompt(state: CombinedState) -> dict:
    """Steps 4-5: Orchestrator triggers Agent 5; Agent 5 reads base_prompt_version."""
    base_prompt = _read_base_prompt_version(state["target_agent"])
    return {
        "base_prompt_version": base_prompt,
        "current_prompt_text": state.get("current_prompt_text") or base_prompt,
        "audit_log": [_postgres_write(
            f"agent5 read base_prompt_version for {state['target_agent']}"
        )],
    }


def agent5_check_and_draft(state: CombinedState) -> dict:
    """Step 6: Agent 5 self-loop - pattern check + semantic check, then drafts."""
    flagged = _agent5_pattern_and_semantic_check(state["coaching_direction"])
    candidate = _agent5_generate_candidate(
        state["target_agent"], state["current_prompt_text"], state["coaching_direction"]
    )
    if flagged:
        candidate["status"] = "Flagged_Injection"
    return {
        "injection_flagged": flagged,
        "candidate": candidate,
        "audit_log": [_postgres_write(
            f"agent5 pattern+semantic check complete, injection_flagged={flagged}"
        )],
    }


def route_injection_check(state: CombinedState) -> Literal["flagged", "clean"]:
    return "flagged" if state["injection_flagged"] else "clean"


def flag_candidate_injection(state: CombinedState) -> dict:
    """Step 7: Agent 5 -> Postgres: prompt_candidates status=Flagged_Injection."""
    return {
        "audit_log": [_postgres_write(
            f"candidate {state['candidate']['id']} -> Flagged_Injection"
        )]
    }


def escalate_to_architect(state: CombinedState) -> dict:
    """Steps 8-9: Orchestrator -> Architect Escalation Inbox; Coach sees
    "Under review"; pauses until the architect Dismisses or Confirms."""
    response = interrupt({
        "ui": "Architect Escalation Inbox",
        "candidate_id": state["candidate"]["id"],
        "coaching_direction": state["coaching_direction"],
        "proposed_prompt_text": state["candidate"]["proposed_prompt_text"],
        "action_required": "Dismiss or Confirm",
    })
    return {
        "escalation_decision": response["decision"],  # "dismiss" | "confirm"
        "coach_visible_status": "Under review",
        "audit_log": [_postgres_write(
            f"architect escalation resolved: {response['decision']}"
        )],
    }


def route_escalation_decision(state: CombinedState) -> Literal["dismiss", "confirm"]:
    return state["escalation_decision"]


def clear_flag_after_dismiss(state: CombinedState) -> dict:
    """Architect dismissed the flag as a false positive -> proceed as Clean."""
    candidate = dict(state["candidate"])
    candidate["status"] = "Pending_Approval"
    return {
        "candidate": candidate,
        "injection_flagged": False,
        "audit_log": [_postgres_write(
            f"candidate {candidate['id']} flag dismissed by architect, resuming clean path"
        )],
    }


def halt_on_confirmed_injection(state: CombinedState) -> dict:
    """Architect confirmed a real injection attempt -> stop, require fresh direction."""
    return {
        "coach_visible_status": "Rejected - injection confirmed",
        "coaching_direction": None,  # force a fresh submission if retried
        "audit_log": [_postgres_write(
            f"candidate {state['candidate']['id']} injection CONFIRMED - workflow halted"
        )],
    }


def propose_candidate_pending(state: CombinedState) -> dict:
    """Step 10 [Clean]: Agent 5 -> Postgres: prompt_candidates status=Pending_Approval."""
    candidate = dict(state["candidate"])
    candidate["status"] = "Pending_Approval"
    return {
        "candidate": candidate,
        "coach_visible_status": "Pending_Approval",
        "audit_log": [_postgres_write(
            f"candidate {candidate['id']} -> Pending_Approval "
            f"({candidate['proposed_prompt_text']})"
        )],
    }


def validate_candidate(state: CombinedState) -> dict:
    """Step 11: Orchestrator -> Agent 4: Validate candidate (faithfulness)."""
    ok = _agent4_validate_faithfulness(state["candidate"])
    return {"faithfulness_ok": ok}


def audit_trail_candidate(state: CombinedState) -> dict:
    """Step 12: Agent 4 -> Postgres: audit_trail for candidate."""
    return {
        "audit_log": [_postgres_write(
            f"audit_trail: candidate {state['candidate']['id']} "
            f"faithfulness_ok={state['faithfulness_ok']}"
        )]
    }


def show_diff_and_get_decision(state: CombinedState) -> dict:
    """Steps 13-16: Orchestrator -> UI: Show Prompt Diff Viewer; UI -> Coach:
    old/new/rationale; pauses until the Coach clicks Accept or Reject."""
    response = interrupt({
        "ui": "Prompt Diff Viewer",
        "old_prompt": state["current_prompt_text"],
        "new_prompt": state["candidate"]["proposed_prompt_text"],
        "rationale": state["candidate"]["rationale"],
    })
    return {
        "coach_decision": response["decision"],  # "accept" | "reject"
        "coach_rationale": response.get("rationale"),
    }


def route_on_decision(state: CombinedState) -> Literal["accept_branch", "reject_branch"]:
    return "accept_branch" if state["coach_decision"] == "accept" else "reject_branch"


def accept_branch(state: CombinedState) -> dict:
    """Steps 17-19: supersede previous approved, mark new Approved, increment attempts."""
    candidate = dict(state["candidate"])
    candidate["status"] = "Approved"
    return {
        "candidate": candidate,
        "current_prompt_text": candidate["proposed_prompt_text"],
        "attempts": state["attempts"] + 1,
        "audit_log": [
            _postgres_write("previous approved prompt -> Superseded"),
            _postgres_write(f"candidate {candidate['id']} -> Approved"),
        ],
    }


def reject_branch(state: CombinedState) -> dict:
    """Steps 23-26: candidate -> Rejected, increment attempts."""
    candidate = dict(state["candidate"])
    candidate["status"] = "Rejected"
    return {
        "candidate": candidate,
        "attempts": state["attempts"] + 1,
        "audit_log": [_postgres_write(
            f"candidate {candidate['id']} -> Rejected "
            f"(rationale: {state.get('coach_rationale') or 'none'})"
        )],
    }


def check_circuit_breaker(state: CombinedState) -> dict:
    """Circuit breaker: max attempts per agent per project = 10 (Approved+Rejected)."""
    tripped = state["attempts"] >= MAX_ATTEMPTS_PER_AGENT_PER_PROJECT
    log = []
    if tripped:
        log.append(_postgres_write(
            f"circuit breaker tripped for agent={state['target_agent']} "
            f"project={state['project_id']} after {state['attempts']} attempts"
        ))
    return {"circuit_breaker_tripped": tripped, "audit_log": log}


def route_after_circuit_breaker(
    state: CombinedState,
) -> Literal["approved_path", "rejected_retry", "breaker_tripped"]:
    if state["circuit_breaker_tripped"]:
        return "breaker_tripped"
    return "approved_path" if state["coach_decision"] == "accept" else "rejected_retry"


def retrigger_and_validate_output(state: CombinedState) -> dict:
    """Steps 20, 22: re-trigger Agent 5 with the newly approved prompt; Agent 4
    validates output. This is the JOIN POINT: once the prompt is approved and
    its output validated, we hand off into the Part B agentic workflow instead
    of ending here."""
    ok = _agent4_validate_output(state["current_prompt_text"])
    return {
        "output_validated": ok,
        "coach_visible_status": "Approved",
        "audit_log": [_postgres_write(
            f"re-triggered with approved prompt; output_validated={ok}"
        )],
    }


def offer_fresh_direction(state: CombinedState) -> dict:
    """After a rejection (and while under the circuit-breaker limit), pause
    and let the Coach either supply a new direction or retry with the same
    one before looping back to Agent 5."""
    response = interrupt({
        "ui": "Coach may submit fresh direction",
        "previous_direction": state["coaching_direction"],
        "previous_rationale": state.get("coach_rationale"),
    })
    fresh = response.get("fresh_direction")
    return {
        "coaching_direction": fresh if fresh else state["coaching_direction"],
        "coaching_feedback_id": None,  # a new Pending row will be opened on re-entry
    }


def stop_circuit_breaker_tripped(state: CombinedState) -> dict:
    return {
        "coach_visible_status": "Halted - attempt limit reached",
        "audit_log": [_postgres_write("workflow halted: circuit breaker limit reached")],
    }


# ===========================================================================
# PART B NODES — Agentic research / reconciliation / synthesis
# ===========================================================================
def configure_project(state: CombinedState) -> dict:
    """UI Layer -> Orchestrator: 'Configure project'.
    Entered right after a prompt has been Approved in Part A."""
    return {
        "run_id": state.get("run_id") or str(uuid.uuid4()),
        "iteration_count": 0,
        "max_iterations": state.get("max_iterations", 3),
    }


def init_orchestration_state(state: CombinedState) -> dict:
    """Orchestrator -> PostgreSQL: 'Initialize orchestration_state'."""
    orchestration_state = {
        "phase": "parallel_execution",
        "started_at": datetime.now(timezone.utc).isoformat(),
    }
    delta = _audit(state, "init_orchestration_state", "initialized", orchestration_state)
    delta["orchestration_state"] = orchestration_state
    return delta


def agent1_research(state: CombinedState) -> dict:
    """Orchestrator -[Trigger]-> Agent 1 Research -> market_intelligence (Draft)."""
    result = {"summary": "market intelligence draft", "sources": []}
    delta = _audit(state, "agent1_research", "draft_written", result)
    delta["market_intelligence"] = result
    return delta


def agent2a_modeler(state: CombinedState) -> dict:
    """Orchestrator -[Trigger]-> Agent 2A Modeler -> documented_process_model (Draft)."""
    result = {"model_type": "documented", "nodes": []}
    delta = _audit(state, "agent2a_modeler", "draft_written", result)
    delta["documented_process_model"] = result
    return delta


def agent2b_analyst(state: CombinedState) -> dict:
    """Orchestrator -[Trigger]-> Agent 2B Analyst -> observed_process_model (Draft)."""
    result = {"model_type": "observed", "nodes": []}
    delta = _audit(state, "agent2b_analyst", "draft_written", result)
    delta["observed_process_model"] = result
    return delta


def validate_drafts(state: CombinedState) -> dict:
    """PostgreSQL -> Orchestrator: 'Validate drafts', then Orchestrator ->
    PostgreSQL: 'audit_trail + status flags'."""
    flags = {
        "market_intelligence": "verified" if state.get("market_intelligence") else "missing",
        "documented_process_model": "verified" if state.get("documented_process_model") else "missing",
        "observed_process_model": "verified" if state.get("observed_process_model") else "missing",
    }
    delta = _audit(state, "validate_drafts", "validated", flags)
    delta["draft_status_flags"] = flags
    return delta


def present_for_coaching(state: CombinedState) -> dict:
    """Orchestrator -> UI Layer: 'Present outputs for coaching'; waits for
    'Coaching feedback (if any)' from the human reviewer."""
    feedback = interrupt(
        {
            "stage": "coaching_drafts",
            "message": "Review draft outputs and provide feedback (or approve).",
            "market_intelligence": state.get("market_intelligence"),
            "documented_process_model": state.get("documented_process_model"),
            "observed_process_model": state.get("observed_process_model"),
        }
    )
    return {"coaching_feedback": feedback.get("feedback")}


def apply_iteration_limits(state: CombinedState) -> dict:
    """Orchestrator note: 'Apply iteration limits'."""
    bump = 1 if state.get("coaching_feedback") else 0
    return {"iteration_count": state.get("iteration_count", 0) + bump}


def route_after_coaching(state: CombinedState) -> str:
    if state.get("coaching_feedback") and state["iteration_count"] < state["max_iterations"]:
        return "agent1_research"  # loop back into parallel execution
    return "reconciliation_gate"


def reconciliation_gate(state: CombinedState) -> dict:
    """Orchestrator: 'Trigger (2A and 2B verified)'."""
    flags = state.get("draft_status_flags", {})
    ready = flags.get("documented_process_model") == "verified" and flags.get(
        "observed_process_model"
    ) == "verified"
    return {"reconciliation_ready": ready}


def agent2c_reconciliation(state: CombinedState) -> dict:
    """Agent 2C: reads documented_process_model + observed_process_model,
    writes reconciled_process_item."""
    reconciled = {
        "from_documented": state.get("documented_process_model"),
        "from_observed": state.get("observed_process_model"),
        "diffs_resolved": True,
    }
    delta = _audit(state, "agent2c_reconciliation", "reconciled_written", reconciled)
    delta["reconciled_process_item"] = reconciled
    return delta


def validate_reconciliation(state: CombinedState) -> dict:
    """PostgreSQL -> Orchestrator: 'Validate reconciliation' -> audit_trail."""
    return _audit(state, "validate_reconciliation", "validated")


def present_reconciliation_panel(state: CombinedState) -> dict:
    """Orchestrator -> UI Layer: 'Present reconciliation & panel view';
    waits for 'Confirm or request re-run'."""
    decision = interrupt(
        {
            "stage": "reconciliation_review",
            "message": "Confirm the reconciled process item, or request a re-run.",
            "reconciled_process_item": state.get("reconciled_process_item"),
        }
    )
    return {"reconciliation_confirmed": decision.get("action") == "confirm"}


def route_after_reconciliation_panel(state: CombinedState) -> str:
    if state.get("reconciliation_confirmed"):
        return "synthesis_gate"
    return "agent2c_reconciliation"  # request re-run


def synthesis_gate(state: CombinedState) -> dict:
    """Orchestrator: 'Trigger with verified inputs'."""
    return {"orchestration_state": {**state.get("orchestration_state", {}), "phase": "synthesis"}}


def agent3_synthesis(state: CombinedState) -> dict:
    """Agent 3 Rec SME: reads market_intelligence + reconciled_process_item,
    writes proposed_interventions (Draft)."""
    interventions = {
        "based_on_market_intelligence": state.get("market_intelligence"),
        "based_on_reconciled_process": state.get("reconciled_process_item"),
        "items": [],
    }
    delta = _audit(state, "agent3_synthesis", "draft_written", interventions)
    delta["proposed_interventions"] = interventions
    return delta


def validate_interventions(state: CombinedState) -> dict:
    """PostgreSQL -> Orchestrator: 'Validate interventions' -> audit_trail."""
    delta = _audit(state, "validate_interventions", "validated")
    delta["interventions_verified"] = True
    return delta


def present_for_coaching_2(state: CombinedState) -> dict:
    """Orchestrator -> UI Layer: 'Present for coaching'; waits for
    'Reiterate (if any)'."""
    feedback = interrupt(
        {
            "stage": "coaching_interventions",
            "message": "Review proposed interventions; reiterate or approve.",
            "proposed_interventions": state.get("proposed_interventions"),
        }
    )
    return {"coaching_feedback": feedback.get("feedback")}


def route_after_coaching_2(state: CombinedState) -> str:
    if state.get("coaching_feedback") and state["iteration_count"] < state["max_iterations"]:
        return "agent3_synthesis"
    return "approval_gate"


def approval_gate(state: CombinedState) -> dict:
    """Orchestrator -> UI Layer: 'HITL Type-2 Approval Gate'
    (Approve / Reject / Rework)."""
    decision = interrupt(
        {
            "stage": "approval_gate",
            "message": "Approve, reject, or send back for rework.",
            "proposed_interventions": state.get("proposed_interventions"),
            "reconciled_process_item": state.get("reconciled_process_item"),
        }
    )
    return {"approval_decision": decision.get("decision")}


def route_after_approval(state: CombinedState) -> str:
    decision = state.get("approval_decision")
    if decision == "approve":
        return "update_status_human_approved"
    if decision == "rework":
        return "agent3_synthesis"
    return "END_REJECTED"


def update_status_human_approved(state: CombinedState) -> dict:
    """Orchestrator -> PostgreSQL: 'Update status Human_Approved'."""
    delta = _audit(state, "update_status_human_approved", "Human_Approved")
    delta["status"] = "Human_Approved"
    return delta


def assemble_roadmap(state: CombinedState) -> dict:
    """Orchestrator: 'Approved interventions promoted to Human_Approved;
    Roadmap assembled.'"""
    roadmap = {
        "interventions": state.get("proposed_interventions"),
        "reconciled_process_item": state.get("reconciled_process_item"),
        "status": "Human_Approved",
        "assembled_at": datetime.now(timezone.utc).isoformat(),
    }
    delta = _audit(state, "assemble_roadmap", "roadmap_assembled", roadmap)
    delta["roadmap"] = roadmap
    return delta


def end_rejected(state: CombinedState) -> dict:
    return _audit(state, "approval_gate", "rejected")


# ===========================================================================
# Graph assembly — one StateGraph, both parts wired together at the join point
# ===========================================================================
def build_graph() -> StateGraph:
    g = StateGraph(CombinedState)

    # --- Part A nodes -------------------------------------------------------
    g.add_node("receive_coaching_direction", receive_coaching_direction)
    g.add_node("write_coaching_feedback", write_coaching_feedback)
    g.add_node("agent5_read_base_prompt", agent5_read_base_prompt)
    g.add_node("agent5_check_and_draft", agent5_check_and_draft)
    g.add_node("flag_candidate_injection", flag_candidate_injection)
    g.add_node("escalate_to_architect", escalate_to_architect)
    g.add_node("clear_flag_after_dismiss", clear_flag_after_dismiss)
    g.add_node("halt_on_confirmed_injection", halt_on_confirmed_injection)
    g.add_node("propose_candidate_pending", propose_candidate_pending)
    g.add_node("validate_candidate", validate_candidate)
    g.add_node("audit_trail_candidate", audit_trail_candidate)
    g.add_node("show_diff_and_get_decision", show_diff_and_get_decision)
    g.add_node("accept_branch", accept_branch)
    g.add_node("reject_branch", reject_branch)
    g.add_node("check_circuit_breaker", check_circuit_breaker)
    g.add_node("retrigger_and_validate_output", retrigger_and_validate_output)
    g.add_node("offer_fresh_direction", offer_fresh_direction)
    g.add_node("stop_circuit_breaker_tripped", stop_circuit_breaker_tripped)

    # --- Part B nodes ---------------------------------------------------
    g.add_node("configure_project", configure_project)
    g.add_node("init_orchestration_state", init_orchestration_state)
    g.add_node("agent1_research", agent1_research)
    g.add_node("agent2a_modeler", agent2a_modeler)
    g.add_node("agent2b_analyst", agent2b_analyst)
    g.add_node("validate_drafts", validate_drafts)
    g.add_node("present_for_coaching", present_for_coaching)
    g.add_node("apply_iteration_limits", apply_iteration_limits)
    g.add_node("reconciliation_gate", reconciliation_gate)
    g.add_node("agent2c_reconciliation", agent2c_reconciliation)
    g.add_node("validate_reconciliation", validate_reconciliation)
    g.add_node("present_reconciliation_panel", present_reconciliation_panel)
    g.add_node("synthesis_gate", synthesis_gate)
    g.add_node("agent3_synthesis", agent3_synthesis)
    g.add_node("validate_interventions", validate_interventions)
    g.add_node("present_for_coaching_2", present_for_coaching_2)
    g.add_node("approval_gate", approval_gate)
    g.add_node("update_status_human_approved", update_status_human_approved)
    g.add_node("assemble_roadmap", assemble_roadmap)
    g.add_node("end_rejected", end_rejected)

    # --- Part A edges ---------------------------------------------------
    g.add_edge(START, "receive_coaching_direction")
    g.add_edge("receive_coaching_direction", "write_coaching_feedback")
    g.add_edge("write_coaching_feedback", "agent5_read_base_prompt")
    g.add_edge("agent5_read_base_prompt", "agent5_check_and_draft")

    g.add_conditional_edges(
        "agent5_check_and_draft",
        route_injection_check,
        {"flagged": "flag_candidate_injection", "clean": "propose_candidate_pending"},
    )

    g.add_edge("flag_candidate_injection", "escalate_to_architect")
    g.add_conditional_edges(
        "escalate_to_architect",
        route_escalation_decision,
        {"dismiss": "clear_flag_after_dismiss", "confirm": "halt_on_confirmed_injection"},
    )
    g.add_edge("clear_flag_after_dismiss", "propose_candidate_pending")
    g.add_edge("halt_on_confirmed_injection", END)  # no approved prompt -> nothing to hand off

    g.add_edge("propose_candidate_pending", "validate_candidate")
    g.add_edge("validate_candidate", "audit_trail_candidate")
    g.add_edge("audit_trail_candidate", "show_diff_and_get_decision")

    g.add_conditional_edges(
        "show_diff_and_get_decision",
        route_on_decision,
        {"accept_branch": "accept_branch", "reject_branch": "reject_branch"},
    )

    g.add_edge("accept_branch", "check_circuit_breaker")
    g.add_edge("reject_branch", "check_circuit_breaker")

    g.add_conditional_edges(
        "check_circuit_breaker",
        route_after_circuit_breaker,
        {
            "approved_path": "retrigger_and_validate_output",
            "rejected_retry": "offer_fresh_direction",
            "breaker_tripped": "stop_circuit_breaker_tripped",
        },
    )

    # *** JOIN POINT ***
    # Previously this went straight to END. Now, once the prompt is Approved
    # and its output validated, we hand off into the Part B agentic pipeline.
    g.add_edge("retrigger_and_validate_output", "configure_project")

    g.add_edge("offer_fresh_direction", "agent5_read_base_prompt")  # loop back
    g.add_edge("stop_circuit_breaker_tripped", END)

    # --- Part B edges --------------------------------------------------
    g.add_edge("configure_project", "init_orchestration_state")

    g.add_edge("init_orchestration_state", "agent1_research")
    g.add_edge("init_orchestration_state", "agent2a_modeler")
    g.add_edge("init_orchestration_state", "agent2b_analyst")
    g.add_edge("agent1_research", "validate_drafts")
    g.add_edge("agent2a_modeler", "validate_drafts")
    g.add_edge("agent2b_analyst", "validate_drafts")

    g.add_edge("validate_drafts", "present_for_coaching")
    g.add_edge("present_for_coaching", "apply_iteration_limits")
    g.add_conditional_edges(
        "apply_iteration_limits",
        route_after_coaching,
        {"agent1_research": "agent1_research", "reconciliation_gate": "reconciliation_gate"},
    )

    g.add_edge("reconciliation_gate", "agent2c_reconciliation")
    g.add_edge("agent2c_reconciliation", "validate_reconciliation")
    g.add_edge("validate_reconciliation", "present_reconciliation_panel")
    g.add_conditional_edges(
        "present_reconciliation_panel",
        route_after_reconciliation_panel,
        {
            "synthesis_gate": "synthesis_gate",
            "agent2c_reconciliation": "agent2c_reconciliation",
        },
    )

    g.add_edge("synthesis_gate", "agent3_synthesis")
    g.add_edge("agent3_synthesis", "validate_interventions")
    g.add_edge("validate_interventions", "present_for_coaching_2")
    g.add_conditional_edges(
        "present_for_coaching_2",
        route_after_coaching_2,
        {"agent3_synthesis": "agent3_synthesis", "approval_gate": "approval_gate"},
    )

    g.add_conditional_edges(
        "approval_gate",
        route_after_approval,
        {
            "update_status_human_approved": "update_status_human_approved",
            "agent3_synthesis": "agent3_synthesis",
            "END_REJECTED": "end_rejected",
        },
    )
    g.add_edge("update_status_human_approved", "assemble_roadmap")
    g.add_edge("assemble_roadmap", END)
    g.add_edge("end_rejected", END)

    return g


def compile_app():
    """Compile with a checkpointer so interrupt()/Command(resume=...) work
    across separate invocations (needed for every HITL gate in both parts)."""
    checkpointer = MemorySaver()
    return build_graph().compile(checkpointer=checkpointer)


# ---------------------------------------------------------------------------
# Example driver: runs a Coach-approves-first-try path straight through both
# parts, resuming past every interrupt until the roadmap is assembled.
# ---------------------------------------------------------------------------
if __name__ == "__main__":
    app = compile_app()
    config = {"configurable": {"thread_id": str(uuid.uuid4())}}

    initial_state: CombinedState = {
        "project_id": "project-42",
        "target_agent": "agent-5-prompt-architect",
        "coaching_feedback_id": None,
        "coaching_direction": "Be more concise and cite sources when possible.",
        "base_prompt_version": None,
        "current_prompt_text": "<current approved prompt>",
        "injection_flagged": None,
        "candidate": None,
        "escalation_decision": None,
        "coach_visible_status": None,
        "faithfulness_ok": None,
        "coach_decision": None,
        "coach_rationale": None,
        "fresh_direction": None,
        "attempts": 0,
        "circuit_breaker_tripped": False,
        "output_validated": None,
        "audit_log": [],
        "project_config": {"name": "demo"},
        "max_iterations": 3,
        "audit_trail": [],
    }

    state = app.invoke(initial_state, config=config)

    while "__interrupt__" in state:
        payload = state["__interrupt__"][0].value

        # Part A interrupts carry "ui"; Part B interrupts carry "stage".
        stage = payload.get("ui") or payload.get("stage")
        print(f"\n--- HITL pause: {stage} ---")
        print(payload.get("message") or payload.get("action_required") or "")

        if stage == "Prompt Diff Viewer":
            resume_value = {"decision": "accept"}
        elif stage == "Architect Escalation Inbox":
            resume_value = {"decision": "dismiss"}
        elif stage == "Coach may submit fresh direction":
            resume_value = {"fresh_direction": None}
        elif stage in ("coaching_drafts", "coaching_interventions"):
            resume_value = {"feedback": None}  # no feedback -> proceed
        elif stage == "reconciliation_review":
            resume_value = {"action": "confirm"}
        elif stage == "approval_gate":
            resume_value = {"decision": "approve"}
        else:
            resume_value = {}

        state = app.invoke(Command(resume=resume_value), config=config)

    print("\nFinal status:", state.get("status"))
    print("Roadmap:", state.get("roadmap"))
    print("\n--- Part A audit log ---")
    for entry in state.get("audit_log", []):
        print(entry)
